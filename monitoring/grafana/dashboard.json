      "id": 1,
      "title": "HTTP Request Volume (Rate)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (method, route)",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
